  "scoped_values": {
    "_description": "Scoped values require additional service-layer checks beyond role",
    "scoped_own_orders": "Filter: WHERE agent_id = req.user.id (for agents) OR client_id = req.user.id (for clients)",
    "scoped_own_drafts": "Filter: WHERE agent_id = req.user.id AND status = 'draft'",
    "scoped_assigned_clients": "Filter: JOIN agent_client_assignments WHERE agent_id = req.user.id",
    "own_group_only": "Pricing: apply client_group_id from JWT, return only that group's price",
    "scoped_own_assignments": "Filter: WHERE agent_id = req.user.id on agent_client_assignments"
