# ═══════════════════════════════════════════════════════════════════
# MaxMarket Environment Configuration
# Copy to .env and adjust for your environment.
# Variables marked [PRODUCTION] MUST be changed before deployment.
# ═══════════════════════════════════════════════════════════════════

# ──── Database ────────────────────────────────────────────────────
POSTGRES_USER=maxmarket_user
POSTGRES_PASSWORD=maxmarket_password           # [PRODUCTION] Change to strong password
POSTGRES_DB=maxmarket_db

# ──── Backend API ─────────────────────────────────────────────────
# Docker Compose sets DATABASE_URL automatically. This is for local dev:
DATABASE_URL=postgresql://maxmarket_user:maxmarket_password@localhost:5432/maxmarket_db

# [PRODUCTION] Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=dev-access-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

NODE_ENV=development                           # [PRODUCTION] Set to 'production'
PORT=3000
LOG_LEVEL=info                                 # debug | info | warn | error

# ──── CORS ────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173              # [PRODUCTION] https://your-domain.com

# ──── JWT Token TTL ───────────────────────────────────────────────
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ──── QA / Testing ────────────────────────────────────────────────
# Set to true to disable login rate limit (10/15min) for QA regression suite.
# Leave unset for production.
# LOGIN_RATE_LIMIT_DISABLED=true

# ──── Frontend ────────────────────────────────────────────────────
VITE_API_BASE_URL=                             # Empty for dev. Production: set if API on different domain

# ──── Production Docker ───────────────────────────────────────────
WEB_PORT=80                                    # Host port for the web service
