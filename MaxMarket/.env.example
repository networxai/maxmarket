# MaxMarket Environment Configuration
# Copy to .env and adjust values for your environment.
# Docker Compose uses these with sensible defaults — works out of the box.
# For production: change POSTGRES_PASSWORD, JWT_ACCESS_SECRET, JWT_REFRESH_SECRET, and NODE_ENV=production.

# ──── Database ────────────────────────────
POSTGRES_USER=maxmarket_user
POSTGRES_PASSWORD=maxmarket_password
POSTGRES_DB=maxmarket_db

# ──── Backend API ─────────────────────────
# DATABASE_URL for local dev (not Docker — Docker Compose sets its own)
DATABASE_URL=postgresql://maxmarket_user:maxmarket_password@localhost:5432/maxmarket_db
JWT_ACCESS_SECRET=dev-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
NODE_ENV=development
PORT=3000

# ──── Frontend ────────────────────────────
# Leave empty for dev (Vite proxy handles routing).
# For production, set to the API base URL.
VITE_API_BASE_URL=
